# Coolify/Container Environment Variables
# Set these in Coolify Environment Variables (recommended),
# or use a local .env file for docker compose.

# Alpaca API Credentials
# Get these from https://app.alpaca.markets/
APCA_API_KEY_ID=your_alpaca_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_here

# Logging Configuration (Docker/Cloud deployments)
LOG_LEVEL=INFO
LOG_DIR=/app/logs
LOG_CONSOLE=true

# CLI Server Configuration (Docker/Cloud deployments)
CLI_HOST=0.0.0.0
CLI_PORT=9000
CLI_TIMEOUT_SECONDS=30

# System Configuration
TZ=America/New_York

# HMM model serialization path (enabled by default in Docker/compose).
# Override if you want a custom location.
HMM_MODEL_PATH=/app/models/regime_hmm.pkl

